package {{package}}.kafka.consumer;

import {{package}}.model.a2a.SendMessageRequest;
import {{package}}.usecase.AgentChatUseCase;
import tools.jackson.core.JacksonException;
import tools.jackson.databind.json.JsonMapper;
{{#lombok}}
import lombok.RequiredArgsConstructor;
import lombok.extern.log4j.Log4j2;
{{/lombok}}
import org.springframework.boot.context.event.ApplicationStartedEvent;
import org.springframework.context.event.EventListener;
import org.springframework.stereotype.Component;
import reactor.core.publisher.Flux;
import reactor.core.publisher.Mono;
import reactor.core.scheduler.Schedulers;
import reactor.kafka.receiver.KafkaReceiver;

{{#lombok}}
@Log4j2
@RequiredArgsConstructor
{{/lombok}}
@Component
public class KafkaConsumer {

{{^lombok}}
    private static final org.slf4j.Logger log = org.slf4j.LoggerFactory.getLogger(KafkaConsumer.class);
{{/lombok}}

    private final KafkaReceiver<String, String> kafkaReceiver;
    private final AgentChatUseCase agentChatUseCase;
    private final JsonMapper jsonMapper;

{{^lombok}}
    public KafkaConsumer(KafkaReceiver<String, String> kafkaReceiver,
                         AgentChatUseCase agentChatUseCase,
                         JsonMapper jsonMapper) {
        this.kafkaReceiver = kafkaReceiver;
        this.agentChatUseCase = agentChatUseCase;
        this.jsonMapper = jsonMapper;
    }
{{/lombok}}

    @EventListener(ApplicationStartedEvent.class)
    public Flux<Void> listenMessages() {
        return kafkaReceiver
                .receiveAutoAck()
                .flatMap(Flux::from)
                .publishOn(Schedulers.newBoundedElastic(Schedulers.DEFAULT_BOUNDED_ELASTIC_SIZE,
                        Schedulers.DEFAULT_BOUNDED_ELASTIC_QUEUESIZE, "kafka"))
                .flatMap(receiverRecord -> {
                    log.info("Record received: {}", receiverRecord.value());
                    try {
                        SendMessageRequest request = jsonMapper.readValue(receiverRecord.value(),
                                SendMessageRequest.class);
                        return agentChatUseCase.chat(request)
                                .doOnSuccess(v -> log.info("Successfully processed task id: {}",
                                        request.getTask_id()));
                    } catch (JacksonException e) {
                        log.error("Error parsing kafka record: {}", receiverRecord.value(), e);
                        return Mono.empty();
                    }
                })
                .doOnError(error -> log.error("Error processing kafka record", error))
                .retry()
                .repeat();
    }
}
