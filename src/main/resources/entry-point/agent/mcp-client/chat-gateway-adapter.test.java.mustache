package {{package}}.mcpclient.adapter;

import static org.junit.jupiter.api.Assertions.assertEquals;
import static org.junit.jupiter.api.Assertions.assertNotNull;
import static org.junit.jupiter.api.Assertions.assertNull;
import static org.mockito.ArgumentMatchers.anyString;
import static org.mockito.Mockito.mock;
import static org.mockito.Mockito.when;

import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import org.springframework.ai.chat.client.ChatClient;
import reactor.test.StepVerifier;

class ChatGatewayAdapterTest {

    private ChatClient chatClient;
    private ChatGatewayAdapter adapter;

    @BeforeEach
    void setUp() {
        chatClient = mock(ChatClient.class);
        adapter = new ChatGatewayAdapter(chatClient);
    }

    @Test
    void sendMessageShouldReturnResponse() {
        // Arrange
        ChatClient.ChatClientRequestSpec requestSpec = mock(ChatClient.ChatClientRequestSpec.class);
        ChatClient.CallResponseSpec callResponse = mock(ChatClient.CallResponseSpec.class);

        when(chatClient.prompt()).thenReturn(requestSpec);
        when(requestSpec.user(anyString())).thenReturn(requestSpec);
        when(requestSpec.call()).thenReturn(callResponse);
        when(callResponse.content()).thenReturn("{\"result\":\"ok\"}");

        // Act & Assert
        StepVerifier.create(adapter.sendMessage("test message"))
                .assertNext(response -> {
                    assertNotNull(response);
                    assertEquals("{\"result\":\"ok\"}", response);
                })
                .verifyComplete();
    }

    @Test
    void sendMessageShouldFilterThinkBlocks() {
        // Arrange
        ChatClient.ChatClientRequestSpec requestSpec = mock(ChatClient.ChatClientRequestSpec.class);
        ChatClient.CallResponseSpec callResponse = mock(ChatClient.CallResponseSpec.class);

        when(chatClient.prompt()).thenReturn(requestSpec);
        when(requestSpec.user(anyString())).thenReturn(requestSpec);
        when(requestSpec.call()).thenReturn(callResponse);
        when(callResponse.content()).thenReturn("<think>reasoning here</think>{\"data\":\"clean\"}");

        // Act & Assert
        StepVerifier.create(adapter.sendMessage("test"))
                .assertNext(response -> assertEquals("{\"data\":\"clean\"}", response))
                .verifyComplete();
    }

    @Test
    void sendMessageShouldHandleNullResponse() {
        // Arrange
        ChatClient.ChatClientRequestSpec requestSpec = mock(ChatClient.ChatClientRequestSpec.class);
        ChatClient.CallResponseSpec callResponse = mock(ChatClient.CallResponseSpec.class);

        when(chatClient.prompt()).thenReturn(requestSpec);
        when(requestSpec.user(anyString())).thenReturn(requestSpec);
        when(requestSpec.call()).thenReturn(callResponse);
        when(callResponse.content()).thenReturn(null);

        // Act & Assert
        StepVerifier.create(adapter.sendMessage("test"))
                .verifyComplete();
    }
}
