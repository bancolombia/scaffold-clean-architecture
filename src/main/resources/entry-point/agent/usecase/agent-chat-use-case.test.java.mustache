package {{package}}.usecase;

import static org.junit.jupiter.api.Assertions.assertEquals;
import static org.junit.jupiter.api.Assertions.assertNotNull;
import static org.mockito.ArgumentMatchers.any;
import static org.mockito.ArgumentMatchers.anyString;
import static org.mockito.Mockito.mock;
import static org.mockito.Mockito.verify;
import static org.mockito.Mockito.verifyNoInteractions;
import static org.mockito.Mockito.when;

import {{package}}.model.a2a.Message;
import {{package}}.model.a2a.Part;
import {{package}}.model.a2a.SendMessageRequest;
import {{package}}.model.a2a.SendMessageResponse;
import {{package}}.model.a2a.TaskState;
import {{package}}.model.chat.gateways.AgentResponseGateway;
import {{package}}.model.chat.gateways.ChatGateway;
import {{package}}.model.chat.gateways.TaskStoreGateway;
import java.util.List;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.DisplayName;
import org.junit.jupiter.api.Test;
import org.mockito.ArgumentCaptor;
import reactor.core.publisher.Mono;
import reactor.test.StepVerifier;

@DisplayName("Agent Chat Use Case Tests")
class AgentChatUseCaseTest {

    private ChatGateway chatGateway;
    private AgentResponseGateway agentResponseGateway;
    private TaskStoreGateway taskStoreGateway;
    private AgentChatUseCase agentChatUseCase;

    @BeforeEach
    void setUp() {
        chatGateway = mock(ChatGateway.class);
        agentResponseGateway = mock(AgentResponseGateway.class);
        taskStoreGateway = mock(TaskStoreGateway.class);
        agentChatUseCase = new AgentChatUseCase(chatGateway, agentResponseGateway, taskStoreGateway);
    }

    @Test
    @DisplayName("Should return success response when ChatGateway succeeds (REST)")
    void chatAndRespondShouldReturnSuccess() {
        SendMessageRequest request = buildRequest("Hello");
        when(chatGateway.sendMessage(anyString())).thenReturn(Mono.just("Hello response"));

        StepVerifier.create(agentChatUseCase.chatAndRespond(request))
                .assertNext(response -> {
                    assertEquals(TaskState.COMPLETED, response.getTask().getStatus().getState());
                    assertNotNull(response.getTask().getId());
                    assertNotNull(response.getMessage());
                    assertEquals("agent", response.getMessage().getRole());
                    assertEquals("Hello response", response.getMessage().extractText());
                })
                .verifyComplete();

        verifyNoInteractions(agentResponseGateway);
    }

    @Test
    @DisplayName("Should publish success response to AgentResponseGateway and TaskStore (Kafka)")
    void chatShouldPublishSuccessResponse() {
        SendMessageRequest request = buildRequest("Hello");
        when(chatGateway.sendMessage(anyString())).thenReturn(Mono.just("Hello response"));
        when(taskStoreGateway.save(any())).thenReturn(Mono.empty());
        when(agentResponseGateway.sendResponse(any(SendMessageResponse.class))).thenReturn(Mono.empty());

        StepVerifier.create(agentChatUseCase.chat(request))
                .verifyComplete();

        ArgumentCaptor<SendMessageResponse> captor = ArgumentCaptor.forClass(SendMessageResponse.class);
        verify(agentResponseGateway).sendResponse(captor.capture());
        assertEquals(TaskState.COMPLETED, captor.getValue().getTask().getStatus().getState());
    }

    private SendMessageRequest buildRequest(String content) {
        return SendMessageRequest.builder()
                .message(Message.builder()
                        .role("user")
                        .contextId("ctx-123")
                        .messageId("msg-123")
                        .parts(List.of(Part.ofText(content)))
                        .build())
                .build();
    }
}
